{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "m3u8-queue-downloader",
  "version": "0.1.0",
  "identifier": "com.m3u8.queue-downloader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "m3u8 队列下载器",
        "width": 800,
        "height": 600,
        "resizable": true,
        "decorations": false,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "publisher": "jaredshuai",
    "shortDescription": "m3u8 queue downloader GUI",
    "longDescription": "A Windows desktop GUI queue manager for N_m3u8DL-CLI."
  }
}
